<% layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-4">
  <div class="col-lg-8 col-md-10">
    
    <!-- Product Card -->
    <div class="card shadow-sm">
      <h3 class="p-3"><%= listing.title %></h3>

      <img
        src="<%= listing.image %>"
        class="card-img-top show-img"
        alt="Product Image"
      />

      <div class="card-body">

        <p class="card-text text-muted mb-2">
          Owned By: <i><%= listing.owner.username %></i>
        </p>

        <p class="card-text text-muted mb-3">
          <%= listing.description %>
        </p>

        <!--  NEW FIELDS -->
        <p><strong>Category:</strong> <%= listing.category %></p>
        <p><strong>Condition:</strong> <%= listing.condition %></p>
        <p><strong>Wants:</strong> <%= listing.exchangeWith %></p>

      </div>
    </div>

    <!--  EXCHANGE BUTTON -->
<% if(currentUser && !currentUser._id.equals(listing.owner._id)) { %>

  <% if(existingRequest) { %>

    <div class="d-grid gap-2 mt-3">
      <button class="btn btn-secondary w-100 mt-3" disabled>
        Request Already Sent &#128231;
      </button>
      <% if(existingRequest && existingRequest.status === "accepted") { %>
        <a href="/chat/<%= listing.owner._id %>" class="btn btn-dark mt-2">
          Chat with Owner
        </a>
      <% } %>
    </div>

  <% } else { %>
    <form method="POST" action="/exchange/request" class="mt-3">

      <input type="hidden" name="listingId" value="<%= listing._id %>">

      <!--  SELECT YOUR PRODUCT -->
      <% if(userListings && userListings.length > 0) { %>
      <select name="myProductId" class="form-control mb-2">
        <% userListings.forEach(item => { %>
          <option value="<%= item._id %>">
            <%= item.title %>
          </option>
        <% }) %>
      </select>

      <button class="btn btn-success w-100">
        Exchange with My Product
      </button>
      <% } else { %>
        <p class="text-danger">
          You need to add your own product first!
        </p>
      <% } %>
    </form>
  <% } %>

<% } %>

    <!-- EDIT / DELETE -->
    <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
      <div class="d-flex gap-3 mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark">
          Edit
        </a>

        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
          <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      </div>
    <% } %>


    <!-- ================= REVIEWS ================= -->
    <div class="mt-5">

      <!-- Header -->
      <% if(!currentUser) { %>
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4 class="fw-bold">Reviews</h4>
        </div>
      <% } else { %>
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4 class="fw-bold">Reviews</h4>

          <a
            href="/listings/<%= listing._id %>/reviews/new"
            class="btn btn-dark btn-sm rounded-pill"
          >
            Write a review
          </a>
        </div>
      <% } %>

      <% if (listing.reviews.length === 0) { %>
        <p class="text-muted">No reviews yet.</p>
      <% } else { %>

        <div class="row row-cols-1 row-cols-md-2 g-4">

          <% listing.reviews.forEach((review) => { %>
            <div class="col shadow-sm p-3 rounded">

              <div class="d-flex gap-3">

                <!-- Avatar -->
                <div>
                  <div
                    class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center"
                    style="width: 48px; height: 48px;"
                  >
                    <strong>
                      <%= review.owner.username.charAt(0).toUpperCase() %>
                    </strong>
                  </div>
                </div>

                <!-- Content -->
                <div>
                  <h6 class="mb-0 fw-semibold">
                    <%= review.owner.username %>
                  </h6>

                  <small class="text-muted">
                    <%= review.createdAt.toLocaleString('default', { month: 'long', year: 'numeric' }) %>
                  </small>

                  <!-- Stars -->
                  <div class="text-warning mt-1">
                    <% for(let i = 0; i < review.rating; i++) { %> ★ <% } %>
                    <% for(let i = review.rating; i < 5; i++) { %> ☆ <% } %>
                  </div>

                  <!-- Comment -->
                  <p class="mt-2 text-secondary">
                    <%= review.comment.length > 160
                      ? review.comment.slice(0, 160) + "..."
                      : review.comment
                    %>
                  </p>
                </div>
              </div>

              <!-- Edit/Delete -->
              <% if(currentUser && currentUser._id.equals(review.owner._id)) { %>
                <div class="mt-3 d-flex gap-2 justify-content-end">
                  <a
                    href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit"
                    class="btn btn-outline-dark btn-sm"
                  >
                    Edit
                  </a>

                  <form
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                    method="POST"
                  >
                    <button type="submit" class="btn btn-danger btn-sm">
                      Delete
                    </button>
                  </form>
                </div>
              <% } %>

            </div>
          <% }) %>

        </div>

      <% } %>

    </div>

  </div>
</div>