<% layout('layouts/boilerplate') %>

<div class="mt-3 mb-5 p-4 bg-light border rounded shadow-sm ">
    <div>
        <div
            class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center"
            style="width: 48px; height: 48px;"
            >
            <strong>
                <%= user.username.charAt(0).toUpperCase() %>
            </strong>
        </div>
        <div>
            <h3 class="mt-2 mb-0 fw-bold">
                <%= user.username %>
            </h3>
        </div>
        

    </div>

    <div class="mt-3">
        <p><b>Email:</b> <%= user.email %></p>
    </div>

    <% if(user.createdAt) { %>
        <p><b>Joined:</b> <%= user.createdAt.toLocaleDateString("en-IN") %></p>
        <% 
            const diff = Date.now() - user.createdAt;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        %>
        <p><b>Member for:</b> <%= days %> days ago</p>
    <% } %>
</div>

<!-- My Products -->
 <div class="mt-3 mb-5 p-4 bg-light border rounded shadow-sm ">
    <h4 class="mt-4">My Products</h4>
    <% listings.forEach(item => { %>
    <div class="card p-2 mt-2">
        <%= item.title %>
    </div>
<% }) %>

 </div>

<!-- My Exchanges -->
 <div class="mt-3 mb-5 p-4 bg-light border rounded shadow-sm ">
    <h4 class="mt-4">My Exchanges</h4>
    <% requests.forEach(req => { %>
    <div class="card p-2 mt-2">
        <%= req.product?.title || "Deleted Product" %> - <%= req.status %>
    </div>
    <% }) %>
 </div>


<!-- My Reviews -->
 <div class="mt-3 mb-5 p-4 bg-light border rounded shadow-sm ">
    <h4 class="mt-4">My Reviews</h4>
    <% reviews.forEach(r => { %>
    <div class="card p-2 mt-2">
        <%= r.comment %>
    </div>
    <% }) %>
</div>